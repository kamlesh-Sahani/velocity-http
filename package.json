{
  "name": "velocity-http",
  "version": "2.0.0",
  "description": "A lightweight, zero-dependency universal HTTP client and fetch wrapper with built-in sequential polling, retry, interceptor hooks, timeout, cancellation, and full TypeScript support. A modern alternative to Axios.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "typecheck": "tsc --noEmit",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "velocity",
    "velocity-http",
    "http",
    "http-client",
    "client",
    "fetch",
    "fetch-wrapper",
    "request",
    "ajax",
    "rest",
    "api",
    "polling",
    "sequential-polling",
    "hooks",
    "interceptors",
    "retry",
    "retry-request",
    "timeout",
    "cancellation",
    "abort-controller",
    "abort-signal",
    "typescript",
    "lightweight",
    "zero-dependency",
    "axios-alternative",
    "isomorphic",
    "universal",
    "node",
    "browser",
    "promise",
    "async"
  ],
  "author": "Kamlesh Sahani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kamlesh-Sahani/velocity-http.git"
  },
  "bugs": {
    "url": "https://github.com/kamlesh-Sahani/velocity-http/issues"
  },
  "homepage": "https://github.com/kamlesh-Sahani/velocity-http#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  }
}
