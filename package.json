{
  "name": "velocity-http",
  "version": "1.3.0",
  "description": "A lightweight, zero-dependency universal HTTP client and fetch wrapper with built-in sequential polling, interceptor hooks, and full TypeScript support. A modern alternative to Axios.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "velocity",
    "velocity-http",
    "http",
    "http-client",
    "client",
    "fetch",
    "fetch-wrapper",
    "request",
    "ajax",
    "rest",
    "api",
    "polling",
    "hooks",
    "interceptors",
    "typescript",
    "lightweight",
    "zero-dependency",
    "axios-alternative",
    "axios",
    "pooling",
    "sequential-polling",
    "retry",
    "interceptor",
    "retry-interceptor",
    "retry-request",
    "timeout",
    "timeout-interceptor",
    "timeout-request",
    "cancellation",
    "abort-controller",
    "abort-request",
    "sequence",
    "sequential-requests",
    "batch",
    "promise",
    "promise-wrapper"
  ],
  "author": "Kamlesh Sahani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kamlesh-Sahani/velocity-http.git"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
